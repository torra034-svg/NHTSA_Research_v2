#| label: library
#| message: false
#| warning: false
#| echo: true
library(tidyverse)
#| label: rur_urb_agg
#| message: false
#| warning: false
#| echo: true
rur_urb_agg <- df_v2 %>%
group_by(ST_CASE, YEAR) %>%
summarize(total_fatals = sum(FATALS.x))
View(rur_urb_agg)
#| label: rur_urb_agg
#| message: false
#| warning: false
#| echo: true
rur_urb_agg <- df_v2 %>%
group_by(YEAR) %>%
summarize(total_fatals = sum(FATALS.x))
View(rur_urb_agg)
View(df_v2)
#| label: rur_urb_agg
#| message: false
#| warning: false
#| echo: true
rur_urb_agg <- df_v2 %>%
group_by(YEAR, location) %>%
summarize(total_fatals = sum(FATALS.x))
