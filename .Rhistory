select(ALC_RES) |>
mutate(ALC_RES = as.numeric(ALC_RES)) |>
filter(!is.na(ALC_RES),
ALC_RES >= 454) |>
unique() |>
arrange(ALC_RES)
age_test <- df_duplicate |>
select(AGE) |>
mutate(AGE = as.numeric (AGE)) |>
filter(!is.na(AGE))
