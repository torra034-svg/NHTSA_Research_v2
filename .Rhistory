library(tidyverse)
library(kableExtra)
library(sf)
library(rnaturalearth)
#| label: tbl-name
#| tbl-cap: "Rural vs Urban Fatality Time-series"
#| tbl-cap-location: top
#| message: false
#| warning: false
#| echo: true
kable(rur_urb_agg)
#| label: tbl-name
#| tbl-cap: "Rural vs Urban Fatality Time-series"
#| tbl-cap-location: top
#| message: false
#| warning: false
#| echo: true
kable(rur_urb_agg,
format = "html")
#| label: tbl-name
#| tbl-cap: "Rural vs Urban Fatality Time-series"
#| tbl-cap-location: top
#| message: false
#| warning: false
#| echo: true
kable(rur_urb_agg,
format = "html") %>%
kable_styling(bootstrap_options = c("striped", "hover", "condensed"))
#| label: tbl-name
#| tbl-cap: "Rural vs Urban Fatality Time-series"
#| tbl-cap-location: top
#| message: false
#| warning: false
#| echo: true
kable(rur_urb_agg,
format = "html",
col.names = c("Year","Location","Total Persons", "Total Fatals")) %>%
kable_styling(bootstrap_options = c("striped", "hover", "condensed"))
#| label: tbl-name
#| tbl-cap: "Rural vs Urban Fatality Time-series"
#| tbl-cap-location: top
#| message: false
#| warning: false
#| echo: true
kable(rur_urb_agg,
format = "html",
col.names = c("Year","Location","Total Persons", "Total Fatals"),
format.args = list(big.mark = ",", scientific = FALSE)) %>%
kable_styling(bootstrap_options = c("striped", "hover", "condensed"))
