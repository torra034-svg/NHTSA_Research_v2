#| label: national-accident-data-cleaning
#| message: false
#| warning: false
#| echo: true
stacked_national_accident_v2 <- stacked_national_accident_v1.5 |>
mutate(COUNTY = if_else(COUNTY > 996, NA, COUNTY),
LATITUDE = if_else(LATITUDE >= 77.0, NA, LATITUDE),
LONGITUD = if_else(LONGITUD > 700, NA, LONGITUD),
ROAD_FNC = if_else(
ROAD_FNC == 9 & YEAR <= 2014 |
ROAD_FNC == 19 & YEAR <= 2014 |
ROAD_FNC == 99 & YEAR <= 2014, ## 2014 and before
NA, ROAD_FNC),
FUNC_SYS = if_else(FUNC_SYS >= 96 & YEAR >= 2015, NA, FUNC_SYS), ## 2015 and after
DAY = if_else(DAY > 31, NA, DAY),
DAY_WEEK = if_else(DAY_WEEK > 7, NA, DAY_WEEK),
MONTH = if_else(MONTH >12, NA, MONTH),
HOUR = if_else(HOUR >24, NA, HOUR),
MINUTE = if_else(MINUTE > 59, NA, MINUTE),
NOT_HOUR = if_else(NOT_HOUR > 24, NA, NOT_HOUR),
NOT_MIN = if_else(NOT_MIN > 59, NA, NOT_MIN),
ARR_HOUR = if_else(ARR_HOUR > 24, NA, ARR_HOUR),
ARR_MIN = if_else(ARR_MIN > 59, NA, ARR_MIN),
HOSP_HR = if_else(HOSP_HR > 24, NA, HOSP_HR),
HOSP_MN = if_else(HOSP_MN > 59, NA, HOSP_MN)
)
