# Chunk 3: import-national-csv-data
#| label: import-national-csv-data
#| message: false
#| warning: false
#| echo: true
# Chunk 4: acc-stacked
#| label: acc-stacked
#| message: false
#| warning: false
#| echo: true
# define acc data frames from environment
acc_list <- mget(ls(pattern = "^acc"))
# bind data frames together
stacked_acc <- acc_list %>%
bind_rows(.id = "source_year") %>%
select(ST_CASE, YEAR, FATALS, A_REGION, A_RU)
# Chunk 5: per-stacked
#| label: per-stacked
#| message: false
#| warning: false
#| echo: true
# define per data frames in environment
per_list <- mget(ls(pattern = "^per"))
# bind data frames
stacked_per <- per_list %>%
bind_rows(.id = "source_year") %>%
select(ST_CASE, YEAR, VEH_NO, PER_NO, A_PTYPE, A_RESTUSE, A_HELMUSE, A_PERINJ, A_AGE4, A_HRACE)
# Chunk 6: veh-stacked
#| label: veh-stacked
#| message: false
#| warning: false
#| echo: true
# define veh data frames in environment
veh_list <- mget(ls(pattern = "^veh"))
# bind data frames
stacked_veh <- veh_list %>%
bind_rows(.id = "source_year") %>%
select(ST_CASE, YEAR, VEH_NO)
# Chunk 7: AUX-join
#| label: AUX-join
#| message: false
#| warning: false
#| echo: true
# Join all AUX files together
AUX <- stacked_per %>%
left_join(stacked_acc, by = c("ST_CASE","YEAR"))
# Chunk 8: remove-old-df
#| label: remove-old-df
#| message: false
#| warning: false
#| echo: true
#| code-fold: TRUE
rm(list = ls(pattern = "^acc"))
rm(list = ls(pattern = "^per"))
rm(list = ls(pattern = "^veh"))
