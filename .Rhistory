library(tidyverse)
library(kableExtra)
library(sf)
library(rnaturalearth)
library(scales) ## add commas
#| label: data-clean
#| message: false
#| warning: false
#| echo: true
df_v2 <- df_v2 %>%
filter(!is.na(location)) %>%
mutate(location = as.factor(location))
View(df_v2)
#| label: data-clean
#| message: false
#| warning: false
#| echo: true
df_v2 <- df_v2 %>%
filter(!is.na(location)) %>%
mutate(location = fct_relevel(as.factor(location),"Urban"))
#| label: rur_urb_agg
#| message: false
#| warning: false
#| echo: true
rur_urb_agg <- df_v2 %>%
group_by(YEAR, location) %>%
summarize(
total_persons = sum(PER_NO),
total_fatals = sum(FATALS.x))
#| label: fig-time-series
#| fig-cap: "Rural vs Urban Fatality Time-series"
#| fig-cap-location: top
#| message: false
#| warning: false
#| echo: true
ggplot(rur_urb_agg, aes(x = YEAR, y = total_fatals)) +
geom_col() +
geom_line(aes(color = location, group = location)) +
scale_x_continuous(breaks = seq(min(rur_urb_agg$YEAR), max(rur_urb_agg$YEAR), by = 1)) +
labs(
x = "Year",
y = "Total Fatalalities",
color = "Location"
) +
theme(axis.text.x = element_text(angle = 45, vjust = 1, hjust = 1))
#| label: tbl-fatality
#| tbl-cap: "Rural vs Urban Fatalities"
#| tbl-cap-location: top
#| message: false
#| warning: false
#| echo: true
kable(rur_urb_agg,
format = "html",
col.names = c("Year","Location","Total Persons", "Total Fatals")) %>%
kable_styling(bootstrap_options = c("striped", "hover", "condensed"))
#| label: poisson-regression
#| message: false
#| warning: false
#| echo: true
fatality_model <- glm(total_fatals ~ location,
data = rur_urb_agg,
family = poisson(link = "log")
)
fatality_model
#| label: library
#| message: false
#| warning: false
#| echo: true
library(tidyverse)
library(kableExtra)
library(sf)
library(rnaturalearth)
library(scales) ## add commas
library(gtsummary) ## needed for tbl_regression
#| label: tbl-fatality-model-exp
#| tbl-cap: "Unadjusted Fatality Model [Exponent Form]"
#| tbl-cap-location: top
#| message: false
#| warning: false
#| echo: true
fatality_model %>%
tbl_regression(
intercept = TRUE,
exponentiate = TRUE,
label = list(total_fatals ~ "Total Fatals",
location ~ "Location"))
#| label: poisson-regression
#| message: false
#| warning: false
#| echo: true
fatality_model <- glm(total_fatals ~ location,
data = rur_urb_agg,
family = poisson(link = "log")
)
fatality_model
#| label: tbl-fatality-model-exp
#| tbl-cap: "Unadjusted Fatality Model [Exponent Form]"
#| tbl-cap-location: top
#| message: false
#| warning: false
#| echo: true
fatality_model %>%
tbl_regression(
intercept = TRUE,
exponentiate = TRUE,
label = list(total_fatals ~ "Total Fatals",
locationRural ~ "Location"))
View(df_v2)
#| label: tbl-fatality-model-exp
#| tbl-cap: "Unadjusted Fatality Model [Exponent Form]"
#| tbl-cap-location: top
#| message: false
#| warning: false
#| echo: true
fatality_model %>%
tbl_regression(
intercept = TRUE,
exponentiate = TRUE,
label = list(total_fatals ~ "Total Fatals",
location ~ "Location"))
#| label: tbl-fatality-model-exp
#| tbl-cap: "Unadjusted Fatality Model [Exponent Form]"
#| tbl-cap-location: top
#| message: false
#| warning: false
#| echo: true
fatality_model %>%
tbl_regression(
intercept = TRUE,
exponentiate = TRUE)
#| label: poisson-regression-unadjusted
#| message: false
#| warning: false
#| echo: true
model1 <- glm(total_fatals ~ location,
data = rur_urb_agg,
family = (link = "log"))
#| label: poisson-regression-unadjusted
#| message: false
#| warning: false
#| echo: true
model1 <- glm(total_fatals ~ location,
data = rur_urb_agg,
family = poisson(link = "log"))
model1
#| label: tbl-fatality-model-exp
#| tbl-cap: "Unadjusted Fatality Model [Exponent Form]"
#| tbl-cap-location: top
#| message: false
#| warning: false
#| echo: true
fatality_model %>%
tbl_regression(
intercept = TRUE,
exponentiate = TRUE)
#| label: overdispersion-test
#| message: false
#| warning: false
#| echo: true
model_ratio <- (model1$deviance / model1$df.residual)
model_ratio
#| label: overdispersion-test
#| message: false
#| warning: false
#| echo: true
model_ratio <- (model1$deviance / model1$df.residual)
model_ratio
model_ratio > 10
#| label: poisson-regression-model
#| message: false
#| warning: false
#| echo: true
model1.qp <- glm(total_fatals ~ location,
data = rur_urb_agg,
family = quasipoisson(link = "log"))
model1.qp
#| label: tbl-poisson-regression-model-qp
#| tbl-cap: "Quasi-poisson Regression Model"
#| tbl-cap-location: top
#| message: false
#| warning: false
#| echo: true
model1.qp %>%
tbl_regression(
exponentiate = TRUE
)
#| label: tbl-poisson-regression-model-qp
#| tbl-cap: "Quasi-poisson Regression Model"
#| tbl-cap-location: top
#| message: false
#| warning: false
#| echo: true
model1.qp %>%
tbl_regression(
exponentiate = TRUE,
label = (location ~ "Location")
)
